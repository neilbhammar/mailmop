{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "routes": [
    {
      "source": "/oauth2/:path*",
      "destination": "https://oauth2.googleapis.com/:path*",
      "methods": ["GET", "POST", "OPTIONS"]
    }
  ]
} 